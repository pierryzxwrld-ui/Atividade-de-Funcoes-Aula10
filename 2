#2) Faça um programa que lê os lados de um retângulo e calcula o seu perímetro a partir de uma função:  Perímetro do retângulo = (2*largura) + (2*comprimento)
def perimetro(largura, comprimento):
    return (2 * largura) + (2 * comprimento)

largura = float(input("Digite a largura do retângulo: "))
comprimento = float(input("Digite o comprimento do retângulo: "))

resultado = perimetro(largura, comprimento)

print("Perímetro do retângulo:", resultado)
