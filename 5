#5) Faça um programa que receba dois números e execute as operações listadas a seguir, de acordo com a escolha do usuário (crie uma função para cada opção).
def somar(a, b):
    return a + b

def subtrair(a, b):
    return a - b

def multiplicar(a, b):
    return a * b

def dividir(a, b):
    if b != 0:
        return a / b
    else:
        return "Erro: Divisão por zero"

num1 = float(input())
num2 = float(input())

print("1 - Somar")
print("2 - Subtrair")
print("3 - Multiplicar")
print("4 - Dividir")
opcao = input()

if opcao == "1":
    print(somar(num1, num2))
elif opcao == "2":
    print(subtrair(num1, num2))
elif opcao == "3":
    print(multiplicar(num1, num2))
elif opcao == "4":
    print(dividir(num1, num2))
else:
    print("Opção inválida")
